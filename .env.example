# Firebase
VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Flask backend (Raspberry Pi local IP or deployed URL)
VITE_API_BASE_URL=http://192.168.1.XX:5000

# ── Data Source Mode ─────────────────────────────────────────
# 'mock'  → fully offline: simulated sensors + hardcoded session data
# 'live'  → fully online: real MQTT sensors + real Firebase sessions
# 'demo'  → hybrid: real Firebase sessions + simulated sensors (no Pi needed)
VITE_DATA_SOURCE=mock

# Local IP of the Raspberry Pi running Mosquitto (find with: hostname -I)
# Only needed when VITE_DATA_SOURCE=live
VITE_RASPBERRY_PI_IP=192.168.1.XX
